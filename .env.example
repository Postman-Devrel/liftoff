# ─── Supabase ────────────────────────────────────────────
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Admin Dashboard ─────────────────────────────────────
# Password for /admin — pick a strong random value
ADMIN_PASSWORD=your-admin-password

# ─── Site URL ────────────────────────────────────────────
# Required in production: the CDN in front of this deployment rewrites the
# Host header to the raw *.vercel.app domain, so request.url can't be trusted
# to build the OAuth callback redirect. Do not include the /liftoff basePath —
# it's appended automatically. Auto-detected from request headers in local dev.
NEXT_PUBLIC_SITE_URL=https://www.postman.com

# Gemini API key for badge generation (scripts/generate-badge.ts)
# Get a free key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-key

# ─── Webhooks ────────────────────────────────────────────
# Fired on module completion, learning path completion, and rank-ups.
# LIFTOFF_WEBHOOK_URL=https://your-endpoint.example.com/liftoff
# Optional: signs the payload with HMAC-SHA256 in the X-Liftoff-Signature header
# LIFTOFF_WEBHOOK_SECRET=your-webhook-secret
