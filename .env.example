# ─── Supabase ────────────────────────────────────────────
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Admin Dashboard ─────────────────────────────────────
# Password for /admin — pick a strong random value
ADMIN_PASSWORD=your-admin-password

# ─── Optional ────────────────────────────────────────────
# Override the public site URL (auto-detected from request headers if not set)
# NEXT_PUBLIC_SITE_URL=https://quickstarts.postman.com

# Gemini API key for badge generation (scripts/generate-badge.ts)
# Get a free key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-key
